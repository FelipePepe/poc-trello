# Pre-production environment variables
# These are PLACEHOLDERS. Set the real values in Vercel dashboard environment variables.
# Do NOT commit real secrets.

DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
PORT=3000
CORS_ORIGIN=https://your-frontend-url.vercel.app

# Auth
JWT_SECRET=change-me-in-vercel-dashboard
JWT_EXPIRY=24h
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-vercel-dashboard
