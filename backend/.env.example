DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
PORT=3000

# PostgreSQL SSL (Aiven)
# Opción A: certificado CA como base64 (Vercel / producción)
PG_SSL_CERT_BASE64=
# Opción B: ruta al archivo ca.pem (desarrollo local)
PG_SSL_CERT_PATH=
# Validar certificado del servidor (true por defecto, false solo para debug)
PG_SSL_REJECT_UNAUTHORIZED=true
CORS_ORIGIN=http://localhost:4200

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
MFA_SECRET=your_totp_secret_here    # Dejalo vacío para auto-generar (se mostrará en la consola al arrancar)
