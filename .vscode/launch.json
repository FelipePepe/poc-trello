{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: npm run dev",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/backend"
    },
    {
      "name": "Frontend: npm start",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm start",
      "cwd": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Frontend + Backend",
      "configurations": ["Backend: npm run dev", "Frontend: npm start"],
      "stopAll": true
    }
  ]
}
